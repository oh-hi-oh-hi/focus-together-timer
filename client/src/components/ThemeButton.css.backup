.theme-floating-btn {
  position: fixed;
  bottom: 84px; /* Above Ko-fi button */
  right: 24px;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08); /* Mac OS glassmorphism style */
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  height: 48px;
  width: 48px;
  text-decoration: none;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  z-index: 1000;
  cursor: pointer;
}

.theme-icon-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 48px;
  height: 48px;
}

.theme-icon {
  font-size: 20px;
  opacity: 0.6;
  transition: all 0.4s ease;
}

.theme-text {
  color: #ffffff;
  font-weight: 500;
  font-size: 14px;
  white-space: nowrap;
  opacity: 0;
  transform: translateX(10px);
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.theme-floating-btn:hover {
  width: 150px; /* expands smoothly */
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 8px 32px rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
}

.theme-floating-btn:hover .theme-icon {
  opacity: 1;
  font-size: 22px;
}

.theme-floating-btn:hover .theme-text {
  opacity: 1;
  transform: translateX(0);
}

/* Modal styles based on instruction */
.theme-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  z-index: 2000;
  display: flex;
  justify-content: center;
  align-items: center;
  animation: fadeIn 0.2s ease-out;
}

.theme-modal-content {
  background: #1c1c1e;
  border-radius: 24px;
  width: 90%;
  max-width: 400px;
  max-height: 85vh;
  overflow-y: auto;
  padding: 32px;
  box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #fff;
  animation: scaleUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.theme-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.theme-modal-header h2 {
  font-size: 1.5rem;
  font-weight: 600;
  margin: 0;
  letter-spacing: -0.5px;
}

.theme-close-btn {
  background: none;
  border: none;
  color: #888;
  font-size: 24px;
  cursor: pointer;
  padding: 0;
  width: 32px;
  height: 32px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: none;
}

.theme-close-btn:hover {
  color: #fff;
  background: none;
  transform: scale(1.1);
}

.theme-section {
  margin-bottom: 24px;
}

.theme-section-title {
  font-size: 0.9rem;
  color: #888;
  margin-bottom: 12px;
  font-weight: 500;
}

.theme-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.theme-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 0.2s;
}

.theme-item:hover {
  background: rgba(255, 255, 255, 0.1);
}

.theme-item.active {
  border-color: var(--accent-color);
  background: rgba(255, 255, 255, 0.1);
}

.theme-item.locked {
  opacity: 0.6;
}

.theme-item-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.theme-color-preview {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.2);
}

.theme-name {
  font-weight: 500;
}

.theme-toast {
  position: fixed;
  bottom: 140px; /* Above the buttons */
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 159, 10, 0.95);
  color: white;
  padding: 12px 24px;
  border-radius: 999px;
  font-weight: 600;
  backdrop-filter: blur(8px);
  z-index: 3000;
  box-shadow: 0 8px 32px rgba(255, 159, 10, 0.3);
  animation: slideUpFade 0.3s ease-out;
}

@keyframes scaleUp {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideUpFade {
  from { opacity: 0; transform: translate(-50%, 20px); }
  to { opacity: 1; transform: translate(-50%, 0); }
}

.theme-purchase-accordion {
  animation: slideDownFade 0.3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  overflow: hidden;
  margin-top: 4px;
}

@keyframes slideDownFade {
  from { opacity: 0; max-height: 0; transform: translateY(-5px); }
  to { opacity: 1; max-height: 80px; transform: translateY(0); }
}

.theme-purchase-btn {
  display: block;
  background: var(--accent-color);
  color: white;
  text-align: center;
  padding: 12px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.2s;
  box-shadow: 0 4px 12px rgba(255, 159, 10, 0.2);
}

.theme-purchase-btn:hover {
  background: var(--accent-dark);
  transform: scale(1.02);
}

.theme-secret-section {
  margin-top: 24px;
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 16px;
}

.theme-secret-toggle {
  font-size: 0.85rem;
  color: #888;
  cursor: pointer;
  text-decoration: underline;
  text-decoration-color: rgba(136, 136, 136, 0.5);
  transition: color 0.2s;
}

.theme-secret-toggle:hover {
  color: #fff;
  text-decoration-color: #fff;
}

.theme-secret-form {
  display: flex;
  gap: 8px;
  justify-content: center;
  animation: fadeIn 0.3s ease-out;
}

.theme-secret-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  padding: 8px 12px;
  color: white;
  font-size: 0.9rem;
  outline: none;
  flex: 1;
  transition: border-color 0.2s;
}

.theme-secret-input:focus {
  border-color: var(--accent-color);
}

.theme-secret-btn {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 0 16px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  box-shadow: none;
}

.theme-secret-btn:hover {
  background: rgba(255, 255, 255, 0.2);
}
